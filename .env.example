# Google Gemini API Key (Required for Gemini-backed analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# CoinGecko API Key (Optional - for higher rate limits)
COINGECKO_API_KEY=your_coingecko_api_key_here

# CryptoCompare API Key (Optional - for additional data sources)
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# Etherscan API Key (Optional - for Ethereum data)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional Airaa integration settings
AIRAA_WEBHOOK_URL=
AIRAA_API_KEY=